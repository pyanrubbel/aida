{
  "manifest_version": 3,
  "name": "AIDA - OLS Automation",
  "version": "1.0.0",
  "description": "Automation Daily Activity OLS",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://ols.marindotech.co.id/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://ols.marindotech.co.id/*"
      ],

      "js": [
        "content.js",
        "config.js",
        "knowledge/master.js",
        "job.js",
        "dom.js",
        "form.js",
        "storage.js",
        "activity.js",
        "panel.js"
      ],

      "css": [
        "style.css"
      ],

      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "AIDA"
  }

}